{
  "$schema": "node_modules/barrelize/schema.json",
  "semi": false,
  "barrels": [
    {
      "root": "src/types",
      "name": "index.ts",
      "include": [
        "**/*.ts"
      ],
      "exclude": [
        "**/*.test.ts",
        "**/index.ts"
      ]
    },
    {
      "root": "src",
      "name": "index.ts",
      "include": [
        "**/*.ts"
      ],
      "exclude": [
        "../database/**",
        "relationship/**",
        "src/models/**",
        "types/**",
        "**/types.ts",
        "**/*.test.ts",
        "**/index.ts"
      ]
    },
    {
      "root": "src/relationship",
      "name": "index.ts",
      "include": [
        "**/*.ts"
      ],
      "exclude": [
        "types/**",
        "**/types.ts",
        "**/*.test.ts",
        "**/index.ts"
      ]
    }
  ]
}