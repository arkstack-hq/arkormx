{
  "$schema": "node_modules/barrelize/schema.json",
  "semi": false,
  "barrels": [
    {
      "root": "src/adapters",
      "name": "index.ts",
      "include": [
        "**/*.ts"
      ],
      "exclude": [
        "**/*.test.ts",
        "**/index.ts"
      ]
    },
    {
      "root": "src/types",
      "name": "index.ts",
      "include": [
        "**/*.ts"
      ],
      "exclude": [
        "**/*.test.ts",
        "**/index.ts"
      ]
    },
    {
      "root": "src",
      "name": "index.ts",
      "include": [
        "*.ts",
        "adapters/index.ts",
        "cli/CliApp.ts",
        "cli/logo.ts",
        "cli/commands/*.ts",
        "database/factories.ts",
        "database/ForeignKeyBuilder.ts",
        "database/Migration.ts",
        "database/SchemaBuilder.ts",
        "database/Seeder.ts",
        "database/TableBuilder.ts",
        "Exceptions/*.ts",
        "helpers/*.ts",
        "types/index.ts"
      ],
      "exclude": [
        "**/*.test.ts",
        "index.ts",
        "models/**",
        "relationship/**"
      ],
      "replace": {
        "/\\.ts$/": ""
      }
    },
    {
      "root": "src/relationship",
      "name": "index.ts",
      "include": [
        "**/*.ts"
      ],
      "exclude": [
        "types/**",
        "**/types.ts",
        "**/*.test.ts",
        "**/index.ts"
      ]
    }
  ]
}