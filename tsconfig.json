{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2023",
    "lib": ["es2022", "DOM"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "declaration": true,
    "sourceMap": true,
    "outDir": "./dist",
    "types": ["node", "vitest"],
    "paths": {
      "src": ["./src"],
      "src/*": ["./src/*"],
      "arkormx": ["./src"]
    }
  },
  "include": [
    "src/**/*",
    "types/**/*",
    "tests/**/*",
    "arkormx.config.ts",
    "arkormx.config.js",
    "arkormx.config.cjs",
    "vitest.config.ts",
    "tsdown.config.ts",
    "packages/plugin-clear-router/tests/decorators.test.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
