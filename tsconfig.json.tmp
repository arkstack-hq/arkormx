{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2023",
    "lib": [
      "es2022",
      "DOM"
    ],
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true,
    "strict": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./",
    "types": [
      "node",
      "vitest"
    ],
    "baseUrl": "."
  },
  "include": [
    "src/**/*",
    "types/**/*",
    "tests/**/*",
    "arkormx.config.ts",
    "arkormx.config.js",
    "arkormx.config.cjs",
    "vitest.config.ts",
    "tsdown.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}