generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model User {
    id        Int      @id @default(autoincrement())
    name      String
    email     String   @unique
    isActive  Int      @default(0)
    createdAt DateTime @default(now())

    @@map("users")
}

model Article {
    id        Int       @id @default(autoincrement())
    title     String
    deletedAt DateTime?

    @@map("articles")
}
